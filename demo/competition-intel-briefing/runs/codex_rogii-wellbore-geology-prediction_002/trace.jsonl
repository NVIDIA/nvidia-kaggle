{"type":"item.started","item":{"id":"item_25","type":"command_execution","command":"/bin/bash -lc \"cat > /tmp/create_rogii_plots.py <<'PY'\nimport csv, json, pathlib, re, sqlite3, textwrap\nbase = pathlib.Path('/nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_002')\nplots = base / 'plots'\nplots.mkdir(parents=True, exist_ok=True)\ncomp='rogii-wellbore-geology-prediction'\n# 1 Top kernel votes from kernel_query/cache\ncon=sqlite3.connect('/nvidia-kaggle/data/kernels.db')\nkernel_rows=con.execute(\\\"select kernel_ref,total_votes from kernels where competition_id=? order by total_votes desc limit 15\\\", (comp,)).fetchall()\n# 2 Kernel vote histogram distribution from kernel_query/cache\nvotes=[r[0] for r in con.execute(\\\"select total_votes from kernels where competition_id=?\\\", (comp,)).fetchall()]\nbins=[(0,9),(10,24),(25,49),(50,99),(100,199),(200,999)]\nhist=[]\nfor lo,hi in bins:\n    count=sum(1 for v in votes if lo<=v<=hi)\n    hist.append((f'{lo}-{hi if hi<999 else \\\"999\\\"}', count))\n# 3 Discussion engagement by comments from discussion_query/cache\ncon2=sqlite3.connect('/nvidia-kaggle/data/discussions.db')\ndisc_rows=con2.execute(\\\"select discussion_id,comment_count from discussions where competition_id=? order by comment_count desc limit 15\\\", (comp,)).fetchall()\n# 4 leaderboard scores from CLI leaderboard snapshot\nlb=[]\ntext=(base/'leaderboard_snapshot.csv').read_text()\nlines=[l for l in text.splitlines() if re.match(r'\"'^'\"\\\\d+,', l) or l.startswith('teamId,')]\nfor row in csv.DictReader(lines):\n    lb.append((row['teamName'], float(row['score'])))\nlb=lb[:20]\nplot_defs={\n 'top_kernel_votes': {\n    'title': 'Top public kernels by votes (top 15 from kernel_query cache)',\n    'source': 'kernel_query',\n    'series': [{'label': ref, 'value': int(v)} for ref,v in kernel_rows],\n    'xlabel': 'Votes'\n },\n 'kernel_vote_distribution': {\n    'title': f'Kernel vote distribution across {len(votes)} cached competition kernels',\n    'source': 'kernel_query',\n    'series': [{'label': label, 'value': int(count)} for label,count in hist],\n    'xlabel': 'Number of kernels'\n },\n 'discussion_comment_engagement': {\n    'title': 'Most-commented competition discussions (top 15 from discussion_query cache)',\n    'source': 'discussion_query',\n    'series': [{'label': str(i), 'value': int(c)} for i,c in disc_rows],\n    'xlabel': 'Comments'\n },\n 'leaderboard_top20_scores': {\n    'title': f'Public leaderboard top-20 RMSE snapshot ({len(lb)} rows available)',\n    'source': 'leaderboard',\n    'series': [{'label': name, 'value': float(score)} for name,score in lb],\n    'xlabel': 'RMSE (lower is better)'\n }\n}\nscript_template = r'''\nimport json, pathlib\nimport matplotlib.pyplot as plt\nhere = pathlib.Path(__file__).resolve().parent\nname = pathlib.Path(__file__).stem\npayload = json.loads((here / f\\\"{name}.json\\\").read_text())\nseries = payload[\\\"series\\\"]\nlabels = [item[\\\"label\\\"] for item in series]\nvalues = [float(item[\\\"value\\\"]) for item in series]\nheight = max(4, 0.35 * len(labels) + 1.5)\nfig, ax = plt.subplots(figsize=(10, height))\ny = range(len(labels))\nax.barh(list(y), values, color=\\\"#4C78A8\\\")\nax.set_yticks(list(y))\nax.set_yticklabels(labels, fontsize=8)\nax.invert_yaxis()\nax.set_xlabel(payload.get(\\\"xlabel\\\", \\\"Value\\\"))\nax.set_title(payload[\\\"title\\\"])\nfor idx, value in enumerate(values):\n    ax.text(value, idx, f\\\" {value:g}\\\", va=\\\"center\\\", fontsize=8)\nax.grid(axis=\\\"x\\\", alpha=0.25)\nfig.tight_layout()\nfig.savefig(here / f\\\"{name}.png\\\", dpi=160)\n'''.lstrip()\nfor name,payload in plot_defs.items():\n    (plots/f'{name}.json').write_text(json.dumps({k:v for k,v in payload.items() if k in ['title','source','series']}, indent=2))\n    (plots/f'{name}.py').write_text(script_template)\nPY\npython /tmp/create_rogii_plots.py\nfor py in /nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_002/plots/*.py; do python \\\"\"'$py\"; done\nls -lh /nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_002/plots\nfor js in /nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_002/plots/*.json; do echo \"'\"\\\\n### \"'$(basename \"$js\")\"; cat \"$js\"; done'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
