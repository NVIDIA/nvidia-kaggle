{"type":"item.started","item":{"id":"item_31","type":"command_execution","command":"/bin/bash -lc \"cat > /tmp/make_rogii_plots.py <<'PY'\nimport json\nfrom pathlib import Path\nimport pandas as pd\n\nrun = Path('/nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_010')\nraw = run / 'raw'\nplots = run / 'plots'\nplots.mkdir(parents=True, exist_ok=True)\ndata = run / 'data' / 'extracted'\n\nkernels = json.load(open(raw / 'top_kernels.json'))\ndiscussions = json.load(open(raw / 'top_discussions.json'))\n\ndef write_json(name, title, source, series):\n    with open(plots / f'{name}.json', 'w') as f:\n        json.dump({'title': title, 'source': source, 'series': series}, f, indent=2)\n\nwrite_json(\n    'top_notebook_votes',\n    'Top 15 public notebooks by Kaggle votes (kernel_query)',\n    'kernel_query',\n    [{'label': k['ref'], 'value': int(k['total_votes'])} for k in kernels[:15]],\n)\nwrite_json(\n    'top_discussion_votes',\n    'Top 15 discussions by votes (discussion_query)',\n    'discussion_query',\n    [{'label': f\\\"{d['discussion_id']}: {d['title'][:48]}\\\", 'value': int(d['votes'])} for d in discussions[:15]],\n)\nwrite_json(\n    'top_discussion_comments',\n    'Top 15 discussions by comment count among fetched rows (discussion_query)',\n    'discussion_query',\n    [{'label': f\\\"{d['discussion_id']}: {d['title'][:48]}\\\", 'value': int(d['comment_count'])} for d in sorted(discussions, key=lambda d: d['comment_count'], reverse=True)[:15]],\n)\n\nwell_rows = []\ntvt_ranges = []\nknown_tvt_frac = []\nfor path in sorted((data / 'train').glob('*__horizontal_well.csv')):\n    well = path.name.split('__')[0]\n    df = pd.read_csv(path, usecols=lambda c: c in {'TVT', 'TVT_input'})\n    well_rows.append({'label': well, 'value': int(len(df))})\n    if 'TVT' in df and df['TVT'].notna().any():\n        tvt_ranges.append({'label': well, 'value': float(df['TVT'].max() - df['TVT'].min())})\n    if 'TVT_input' in df:\n        known_tvt_frac.append({'label': well, 'value': float(df['TVT_input'].notna().mean() * 100.0)})\nwrite_json(\n    'largest_train_wells_by_rows',\n    f'Largest 20 train wells by horizontal-row count among {len(well_rows)} wells (competition CSVs)',\n    'competition_dataset_download',\n    sorted(well_rows, key=lambda x: x['value'], reverse=True)[:20],\n)\nwrite_json(\n    'largest_tvt_ranges',\n    f'Largest 20 train wells by target TVT range among {len(tvt_ranges)} wells (competition CSVs)',\n    'competition_dataset_download',\n    sorted(tvt_ranges, key=lambda x: x['value'], reverse=True)[:20],\n)\n# Also save summary for brief.\nsummary = {\n    'train_horizontal_wells': len(list((data / 'train').glob('*__horizontal_well.csv'))),\n    'train_typewells': len(list((data / 'train').glob('*__typewell.csv'))),\n    'test_horizontal_wells': len(list((data / 'test').glob('*__horizontal_well.csv'))),\n    'test_typewells': len(list((data / 'test').glob('*__typewell.csv'))),\n    'train_total_horizontal_rows': int(sum(x['value'] for x in well_rows)),\n    'train_row_count_min': int(min(x['value'] for x in well_rows)),\n    'train_row_count_median': float(pd.Series([x['value'] for x in well_rows]).median()),\n    'train_row_count_max': int(max(x['value'] for x in well_rows)),\n    'tvt_range_min': float(pd.Series([x['value'] for x in tvt_ranges]).min()),\n    'tvt_range_median': float(pd.Series([x['value'] for x in tvt_ranges]).median()),\n    'tvt_range_max': float(pd.Series([x['value'] for x in tvt_ranges]).max()),\n    'known_tvt_input_pct_median': float(pd.Series([x['value'] for x in known_tvt_frac]).median()),\n}\nwith open(raw / 'dataset_profile_summary.json', 'w') as f:\n    json.dump(summary, f, indent=2)\nPY\npython /tmp/make_rogii_plots.py\ncat > /tmp/render_plot_template.py <<'PY'\nimport json\nfrom pathlib import Path\nimport matplotlib.pyplot as plt\nimport sys\npath = Path(sys.argv[1])\nwith open(path) as f:\n    obj = json.load(f)\nseries = obj['series']\nlabels = [s['label'] for s in series]\nvalues = [s['value'] for s in series]\nheight = max(4, 0.36 * len(series) + 1.3)\nfig, ax = plt.subplots(figsize=(11, height))\ny = list(range(len(series)))\nax.barh(y, values, color='#4C78A8')\nax.set_yticks(y)\nax.set_yticklabels(labels, fontsize=8)\nax.invert_yaxis()\nax.set_title(obj['title'], fontsize=12, pad=12)\nax.set_xlabel('Value')\nax.grid(axis='x', alpha=0.25)\nfor i, v in enumerate(values):\n    ax.text(v, i, f' {v:.0f}' if abs(v) >= 10 else f' {v:.2f}', va='center', fontsize=8)\nfig.tight_layout()\nfig.savefig(path.with_suffix('.png'), dpi=160, bbox_inches='tight')\nPY\nPLOTS=/nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_010/plots\nfor j in \\\"\"'$PLOTS\"/*.json; do cp /tmp/render_plot_template.py \"${j%.json}.py\"; python \"${j%.json}.py\" \"$j\"; done\nls -lh \"$PLOTS\" && cat /nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_010/raw/dataset_profile_summary.json'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
