{"type":"item.started","item":{"id":"item_27","type":"command_execution","command":"/bin/bash -lc \"mkdir -p /nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_022/plots\ncat > /tmp/rogii_make_plots.py <<'PY'\nimport json, re\nfrom pathlib import Path\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\n\nbase = Path('/nvidia-kaggle/data/competitions/rogii-wellbore-geology-prediction')\nout = Path('/nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_022/plots')\nout.mkdir(parents=True, exist_ok=True)\ntrain_files = sorted((base/'train').glob('*__horizontal_well.csv'))\nrows=[]\nfor fp in train_files:\n    well=fp.name.split('__')[0]\n    h=pd.read_csv(fp)\n    total=len(h)\n    hidden=int(h['TVT_input'].isna().sum()) if 'TVT_input' in h.columns else 0\n    visible=total-hidden\n    tvt=h['TVT'].dropna() if 'TVT' in h.columns else pd.Series(dtype=float)\n    gr=h['GR'].dropna() if 'GR' in h.columns else pd.Series(dtype=float)\n    rows.append({\n        'well': well,\n        'rows': total,\n        'visible_rows': visible,\n        'eval_rows': hidden,\n        'eval_frac': hidden/total if total else np.nan,\n        'tvt_min': float(tvt.min()) if len(tvt) else np.nan,\n        'tvt_max': float(tvt.max()) if len(tvt) else np.nan,\n        'tvt_range': float(tvt.max()-tvt.min()) if len(tvt) else np.nan,\n        'gr_missing_frac': float(h['GR'].isna().mean()) if 'GR' in h else np.nan,\n        'gr_mean': float(gr.mean()) if len(gr) else np.nan,\n    })\nsummary=pd.DataFrame(rows)\nsummary.to_csv(out/'train_well_summary.csv', index=False)\n\n# Plot 1: train well row-count distribution and eval fraction summary\nseries=[\n    {'label':'train wells','value':int(len(summary)),'provenance':'derived'},\n    {'label':'median horizontal rows/well','value':float(summary['rows'].median()),'provenance':'derived'},\n    {'label':'median hidden eval rows/well','value':float(summary['eval_rows'].median()),'provenance':'derived'},\n    {'label':'median hidden eval fraction','value':float(summary['eval_frac'].median()),'provenance':'derived'},\n]\n(Path(out/'dataset_shape_summary.json')).write_text(json.dumps({\n    'title':'Derived training-set shape summary',\n    'source':'local competition data /nvidia-kaggle/data/competitions/rogii-wellbore-geology-prediction/train',\n    'series':series,\n}, indent=2))\nfig, ax = plt.subplots(figsize=(9,5))\nax.hist(summary['rows'], bins=30, color='#4c78a8', alpha=.85)\nax.axvline(summary['rows'].median(), color='#f58518', lw=2, label=f\\\"median={summary['rows'].median():.0f}\\\")\nax.set_title('Training horizontal-well row counts (derived)')\nax.set_xlabel('Rows per horizontal well')\nax.set_ylabel('Number of wells')\nax.legend()\nfig.tight_layout(); fig.savefig(out/'well_row_count_distribution.png', dpi=160); plt.close(fig)\n\n# Plot 2: TVT ranges and GR missing\nplot_df=summary.sort_values('tvt_range', ascending=False).head(25).iloc[::-1]\n(Path(out/'top_tvt_ranges.json')).write_text(json.dumps({\n    'title':'Top 25 training wells by TVT range (derived)',\n    'source':'local competition train horizontal_well.csv files',\n    'series':[{'label':r.well,'value':float(r.tvt_range),'provenance':'derived'} for r in plot_df.itertuples()],\n}, indent=2))\nfig, ax = plt.subplots(figsize=(9,7))\nax.barh(plot_df['well'], plot_df['tvt_range'], color='#54a24b')\nax.set_title('Largest per-well TVT ranges in train (derived)')\nax.set_xlabel('TVT max - min (ft)')\nax.set_ylabel('Well')\nfig.tight_layout(); fig.savefig(out/'top_tvt_ranges.png', dpi=160); plt.close(fig)\n\n# Plot 3: title-claimed score ladder from gathered kernel titles\nkernels=json.load(open('/tmp/rogii_kernels_query_now.json'))\nscore_rows=[]\npatterns=[r'LB[:\\\\s\\\\[\\\\]-]*([0-9]+\\\\.[0-9]+)', r'\\\\b([0-9]+\\\\.[0-9]+)\\\\b']\nfor k in kernels:\n    title=k.get('title') or ''\n    ref=k.get('ref') or ((k.get('author_username') or k.get('author') or '')+'/'+(k.get('slug') or ''))\n    score=None\n    if 'top 3' in title.lower():\n        continue\n    for pat in patterns:\n        m=re.search(pat, title, flags=re.I)\n        if m:\n            val=float(m.group(1))\n            if 5 <= val <= 20:\n                score=val; break\n    if score is not None:\n        score_rows.append({'label':title[:55], 'value':score, 'provenance':'title-claim', 'ref':ref, 'url':f'https://www.kaggle.com/code/{ref}'})\n# dedupe label/value\nseen=set(); ded=[]\nfor r in score_rows:\n    key=(r['ref'], r['value'])\n    if key not in seen:\n        seen.add(key); ded.append(r)\nded=sorted(ded, key=lambda r:r['value'])[:16]\n(Path(out/'title_claimed_score_ladder.json')).write_text(json.dumps({\n    'title':'Notebook-title claimed LB/CV scores (unverified title claims)',\n    'source':'/tmp/rogii_kernels_query_now.json gathered from Kaggle kernel query in this run',\n    'series':ded,\n}, indent=2))\nfig, ax = plt.subplots(figsize=(10,6))\nlabels=[r['label'] for r in ded][::-1]\nvals=[r['value'] for r in ded][::-1]\nbars=ax.barh(labels, vals, color='#e45756', hatch='///', edgecolor='#7f1d1d')\nax.set_title('Notebook-title claimed scores (hatched = unverified title claim)')\nax.set_xlabel('Claimed RMSE/LB/CV value; lower is better')\nax.set_xlim(min(vals)-0.5 if vals else 0, max(vals)+0.8 if vals else 1)\nax.bar_label(bars, fmt='%.3f', padding=3, fontsize=8)\nfig.tight_layout(); fig.savefig(out/'title_claimed_score_ladder.png', dpi=160); plt.close(fig)\n\n# Plot 4: high-signal public notebooks by votes, clearly popularity not performance\npublic=sorted(kernels, key=lambda k: k.get('total_votes') or k.get('votes') or 0, reverse=True)[:20]\n(Path(out/'top_public_notebooks_by_votes.json')).write_text(json.dumps({\n    'title':'Top 20 gathered public notebooks by votes (popularity, not performance)',\n    'source':'/tmp/rogii_kernels_query_now.json gathered from Kaggle kernel query in this run',\n    'series':[{'label':(k.get('title') or '')[:60], 'value':int(k.get('total_votes') or k.get('votes') or 0), 'provenance':'verified', 'ref':k.get('ref')} for k in public],\n}, indent=2))\nplot_public=list(reversed(public))\nfig, ax = plt.subplots(figsize=(10,7))\nvals=[int(k.get('total_votes') or k.get('votes') or 0) for k in plot_public]\nlabels=[(k.get('title') or '')[:60] for k in plot_public]\nax.barh(labels, vals, color='#72b7b2')\nax.set_title('Top gathered public notebooks by votes (popularity only)')\nax.set_xlabel('Votes gathered from Kaggle kernel query')\nfig.tight_layout(); fig.savefig(out/'top_public_notebooks_by_votes.png', dpi=160); plt.close(fig)\n\nprint(summary.describe(include='all').to_string())\nprint('wrote plots to', out)\nPY\npython /tmp/rogii_make_plots.py\nls -la /nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_022/plots\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
