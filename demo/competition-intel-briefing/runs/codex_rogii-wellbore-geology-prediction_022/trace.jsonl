{"type":"item.started","item":{"id":"item_35","type":"command_execution","command":"/bin/bash -lc \"cat > /tmp/rogii_render_json_plots.py <<'PY'\nimport json, math\nfrom pathlib import Path\nimport matplotlib.pyplot as plt\nimport pandas as pd\n\nout = Path('/nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_022/plots')\nsummary = pd.read_csv(out/'train_well_summary.csv')\ncounts = summary['rows']\nbins = pd.cut(counts, bins=30)\nhist = counts.groupby(bins, observed=False).size()\nseries=[]\nfor interval, count in hist.items():\n    label=f'{int(math.floor(interval.left))}-{int(math.ceil(interval.right))}'\n    series.append({'label': label, 'value': int(count), 'provenance':'derived', 'bin_left': float(interval.left), 'bin_right': float(interval.right)})\n(out/'well_row_count_distribution.json').write_text(json.dumps({\n    'title':'Training horizontal-well row-count distribution (derived histogram)',\n    'source':'plots/train_well_summary.csv derived from local train horizontal_well.csv files',\n    'series': series,\n    'median_rows': float(counts.median())\n}, indent=2))\n\nscripts = {\n'well_row_count_distribution.py': r'''\nimport json\nfrom pathlib import Path\nimport matplotlib.pyplot as plt\np=Path(__file__).with_suffix('.json')\ndata=json.loads(p.read_text())\nlabels=[s['label'] for s in data['series']]\nvals=[s['value'] for s in data['series']]\ncenters=[(s['bin_left']+s['bin_right'])/2 for s in data['series']]\nwidths=[s['bin_right']-s['bin_left'] for s in data['series']]\nfig, ax=plt.subplots(figsize=(9,5))\nax.bar(centers, vals, width=widths, color='#4c78a8', alpha=.85, align='center')\nax.axvline(data['median_rows'], color='#f58518', lw=2, label=f\\\"median={data['median_rows']:.0f}\\\")\nax.set_title(data['title'])\nax.set_xlabel('Rows per horizontal well')\nax.set_ylabel('Number of wells')\nax.legend()\nfig.tight_layout(); fig.savefig(Path(__file__).with_suffix('.png'), dpi=160)\n''',\n'top_tvt_ranges.py': 