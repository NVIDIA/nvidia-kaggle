{"type":"item.started","item":{"id":"item_35","type":"command_execution","command":"/bin/bash -lc \"cat > /tmp/make_rogii_plots.py <<'PY'\nimport json, re\nfrom pathlib import Path\n\nrun = Path('/nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_015')\nplots = run / 'plots'\nplots.mkdir(parents=True, exist_ok=True)\n\nkernels = json.load(open(run / 'kernel_query_top30.json'))\ndiscussions = json.load(open(run / 'discussion_query_top30.json'))\ncomments = json.load(open(run / 'discussion_query_comments20.json'))\n\n# 1) Top public notebooks by votes, as gathered by kernel_query.\nseries = [\n    {'label': k['ref'], 'value': int(k['total_votes'])}\n    for k in kernels[:15]\n]\njson.dump({\n    'title': 'Public notebooks by votes вҖ” top 15 gathered (votes, not leaderboard rank)',\n    'source': 'kernel_query',\n    'series': series,\n}, open(plots / 'top_notebook_votes.json', 'w'), indent=2)\n\n# 2) Top discussions by votes.\nseries = [\n    {'label': str(d['discussion_id']), 'value': int(d['votes'])}\n    for d in discussions[:15]\n]\njson.dump({\n    'title': 'Competition discussions by votes вҖ” top 15 gathered',\n    'source': 'discussion_query',\n    'series': series,\n}, open(plots / 'top_discussion_votes.json', 'w'), indent=2)\n\n# 3) Discussion engagement by comment count.\nseries = [\n    {'label': str(d['discussion_id']), 'value': int(d['comment_count'])}\n    for d in comments[:12]\n]\njson.dump({\n    'title': 'Most commented discussions вҖ” top 12 gathered',\n    'source': 'discussion_query',\n    'series': series,\n}, open(plots / 'top_discussion_comments.json', 'w'), indent=2)\n\n# 4) Score ladder from concrete score numbers embedded in gathered notebook titles.\nscore_series = []\nfor k in kernels:\n    title = k['title']\n    ref = k['ref']\n    match = re.search(r'LB[:\\\\s\\\\[гҖҗ-]*(\\\\d+(?:[\\\\.-]\\\\d+)?)', title, re.I)\n    if not match:\n        match = re.search(r'\"'^('\"\\\\d+[\\\\.-]\\\\d+)\\\\s+ROGII', title, re.I)\n    if match:\n        score = float(match.group(1).replace('-', '.'))\n        score_series.append({'label': ref, 'value': score})\n# keep only plausible RMSE values explicitly encoded in titles, sorted lower better\nscore_series = sorted(score_series, key=lambda x: x['value'])\njson.dump({\n    'title': 'Score ladder from gathered notebook titles (RMSE, lower is better)',\n    'source': 'kernel_query',\n    'series': score_series,\n}, open(plots / 'notebook_title_score_ladder.json', 'w'), indent=2)\n\n# Write renderer scripts that read only their adjacent JSON.\nrenderer = r'''\nimport json\nfrom pathlib import Path\nimport matplotlib.pyplot as plt\n\njson_path = Path(__file__).with_suffix('.json')\nout_path = Path(__file__).with_suffix('.png')\ndata = json.load(open(json_path))\nseries = data['series']\nlabels = [item['label'] for item in series]\nvalues = [item['value'] for item in series]\nheight = max(3.8, 0.38 * len(series) + 1.4)\nfig, ax = plt.subplots(figsize=(11, height))\ny = range(len(series))\nax.barh(list(y), values, color='#2a6fbb')\nax.set_yticks(list(y))\nax.set_yticklabels(labels, fontsize=8)\nax.invert_yaxis()\nax.set_title(data['title'], loc='left', fontsize=12, pad=12)\nax.set_xlabel('Value')\nax.grid(axis='x', alpha=0.25)\nfor idx, value in enumerate(values):\n    ax.text(value, idx, f' {value:g}', va='center', fontsize=8)\nfig.tight_layout()\nfig.savefig(out_path, dpi=180, bbox_inches='tight')\n'''\nfor name in ['top_notebook_votes', 'top_discussion_votes', 'top_discussion_comments', 'notebook_title_score_ladder']:\n    (plots / f'{name}.py').write_text(renderer)\nPY\npython /tmp/make_rogii_plots.py\nfor py in /nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_015/plots/*.py; do python \\\"\"'$py\"; done\nls -lh /nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_015/plots'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
