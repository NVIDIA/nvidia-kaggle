tps://www.kaggle.com/competitions/rogii-wellbore-geology-prediction/discussion/702919\\\", \\\"provenance\\\": \\\"discussion stated RMSE\\\"},\n    {\\\"label\\\": \\\"XGB starter CV\\\", \\\"value\\\": 15.0, \\\"ref\\\": \\\"cdeotte/xgb-starter-cv-15\\\", \\\"url\\\": \\\"https://www.kaggle.com/code/cdeotte/xgb-starter-cv-15\\\", \\\"provenance\\\": \\\"kernel title claim\\\"},\n    {\\\"label\\\": \\\"NN starter CV\\\", \\\"value\\\": 15.5, \\\"ref\\\": \\\"cdeotte/nn-starter-cv-15-5\\\", \\\"url\\\": \\\"https://www.kaggle.com/code/cdeotte/nn-starter-cv-15-5\\\", \\\"provenance\\\": \\\"kernel title claim\\\"},\n    {\\\"label\\\": \\\"Flat formation naive\\\", \\\"value\\\": 55.0, \\\"discussion_id\\\": 702919, \\\"url\\\": \\\"https://www.kaggle.com/competitions/rogii-wellbore-geology-prediction/discussion/702919\\\", \\\"provenance\\\": \\\"discussion stated RMSE\\\"},\n]\nscore_json = {\\\"title\\\": \\\"Gathered score ladder (RMSE; lower is better; title claims are unverified)\\\", \\\"source\\\": \\\"kernel_query + discussion_read\\\", \\\"series\\\": score_series}\n(out/'score_ladder.json').write_text(json.dumps(score_json, indent=2), encoding='utf-8')\n\n# Plot 2: top public notebooks by votes from kernel_query (popularity, not performance).\nkernels = json.load(open('/tmp/rogii_kernels.json'))[:12]\nvote_series = [{\\\"label\\\": k['title'][:48] + ('…' if len(k['title']) > 48 else ''), \\\"value\\\": int(k['total_votes']), \\\"ref\\\": k['ref'], \\\"url\\\": 'https://www.kaggle.com/code/'+k['ref']} for k in kernels]\n(out/'top_notebook_votes.json').write_text(json.dumps({\\\"title\\\":\\\"Top 12 gathered public notebooks by votes (popularity, not rank)\\\", \\\"source\\\":\\\"kernel_query\\\", \\\"series\\\": vote_series}, indent=2), encoding='utf-8')\n\n# Plot 3: train data distribution from local competition data cache fetched for this run.\nrows=[]\nfor p in glob.glob(str(base/'train/*__horizontal_well.csv')):\n    df=pd.read_csv(p, usecols=lambda c: c in {'TVT_input','TVT','MD','GR'})\n    rows.append({\n        'well': Path(p).name.split('__')[0],\n        'rows': len(df),\n        'eval_nan': int(df['TVT_input'].isna().sum()),\n        'gr_missing': int(df['GR'].isna().sum()),\n    })\ntrain = pd.DataFrame(rows)\n# Decile bins for evaluation-zone length; values are counts of wells.\nbins = pd.qcut(train['eval_nan'], q=10, duplicates='drop')\ncounts = bins.value_counts().sort_index()\nseries = []\nfor interval, value in counts.items():\n    series.append({\\\"label\\\": f\\\"{int(interval.left)+1:,}-{int(interval.right):,} rows\\\", \\\"value\\\": int(value)})\n(out/'eval_zone_length_deciles.json').write_text(json.dumps({\\\"title\\\":\\\"Train wells by hidden/evaluation-zone length decile\\\", \\\"source\\\":\\\"local competition data\\\", \\\"series\\\": series, \\\"summary\\\": {\\\"train_wells\\\": int(len(train)), \\\"mean_eval_rows\\\": float(train['eval_nan'].mean()), \\\"max_eval_rows\\\": int(train['eval_nan'].max()), \\\"sample_submission_rows\\\": int(pd.read_csv(base/'sample_submission.csv').shape[0])}}, indent=2), encoding='utf-8')\n\n# Render scripts that read their paired JSON.\nscript = r'''\nfrom pathlib import Path\nimport json\nimport matplotlib.pyplot as plt\nimport sys\npath = Path(sys.argv[1])\ndata = json.loads(path.read_text())\nseries = data['series']\nlabels = [s['label'] for s in series]\nvalues = [s['value'] for s in series]\nheight = max(4.5, 0.38 * len(series) + 1.6)\nfig, ax = plt.subplots(figsize=(10, height))\ny = range(len(series))\nax.barh(list(y), values, color='#76B900')\nax.set_yticks(list(y), labels)\nax.invert_yaxis()\nax.set_title(data['title'])\nax.set_xlabel('Value')\nax.grid(axis='x', alpha=0.25)\nfor idx, value in enumerate(values):\n    ax.text(value, idx, f' {value:g}', va='center', fontsize=9)\nfig.tight_layout()\nfig.savefig(path.with_suffix('.png'), dpi=180)\n'''\nfor name in ['score_ladder','top_notebook_votes','eval_zone_length_deciles']:\n    py = out/f'{name}.py'\n    py.write_text(script, encoding='utf-8')\n    os.system(f'python {py} {out/name}.json')\nprint('Wrote plots:', sorted(p.name for p in out.iterdir()))\nPY\npython /tmp/create_rogii_plots.py\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
