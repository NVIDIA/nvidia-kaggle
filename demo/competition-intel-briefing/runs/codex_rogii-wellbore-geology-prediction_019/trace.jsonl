{"type":"item.started","item":{"id":"item_32","type":"command_execution","command":"/bin/bash -lc \"cat > /tmp/create_rogii_plots.py <<'PY'\nimport csv, json, pathlib, re\nbase=pathlib.Path('/nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_019')\nraw=base/'raw'; plots=base/'plots'; plots.mkdir(parents=True, exist_ok=True)\n# 1 leaderboard top 20\nrows=[]\nwith open(raw/'leaderboard_snapshot.csv', newline='') as f:\n    text=f.read().splitlines()\n# remove warning/next token lines until csv header\ncsv_lines=[]; start=False\nfor line in text:\n    if line.startswith('teamId,'):\n        start=True\n    if start and line.strip():\n        csv_lines.append(line)\nreader=csv.DictReader(csv_lines)\nfor row in reader:\n    if len(rows) >= 20: break\n    rows.append({\n        'label': row['teamName'],\n        'id': row['teamId'],\n        'value': float(row['score']),\n        'provenance': 'verified',\n    })\n(plots/'public_leaderboard_top20_rmse.json').write_text(json.dumps({\n    'title': 'ROGII public leaderboard top 20 RMSE snapshot, fetched 2026-06-13',\n    'source': 'kaggle competitions leaderboard rogii-wellbore-geology-prediction --show -v',\n    'series': rows,\n}, indent=2))\n# 2 kernels votes top 20\nkernels=json.loads((raw/'kernels_top80_vote.json').read_text())[:20]\n(plots/'public_notebooks_top20_votes.json').write_text(json.dumps({\n    'title': 'Top 20 public notebooks by votes (popularity, not rank)',\n    'source': 'kernel_query rogii-wellbore-geology-prediction --limit 80 --as-json from cached Kaggle API ingest',\n    'series': [{\n        'label': k['title'], 'id': k['ref'], 'value': int(k['total_votes']), 'provenance': 'verified'\n    } for k in kernels],\n}, indent=2))\n# 3 discussions top 15 by comment_count to show activity depth\ndisc=json.loads((raw/'discussions_top80_votes.json').read_text())\ndisc_sorted=sorted(disc, key=lambda d: (int(d.get('comment_count') or 0), int(d.get('votes') or 0)), reverse=True)[:15]\n(plots/'discussions_top15_comments.json').write_text(json.dumps({\n    'title': 'Top 15 discussions by comment count (activity depth)',\n    'source': 'discussion_query rogii-wellbore-geology-prediction --limit 80 --as-json after discussion_ingest',\n    'series': [{\n        'label': d['title'], 'id': str(d['discussion_id']), 'value': int(d.get('comment_count') or 0), 'provenance': 'verified'\n    } for d in disc_sorted],\n}, indent=2))\n# 4 score ladder with title claims + verified LB bands\nseries=[]\nfor label, value, ident, prov in [\n    ('Public LB #1 snapshot', rows[0]['value'], rows[0]['id'], 'verified'),\n    ('Public LB #20 snapshot', rows[-1]['value'], rows[-1]['id'], 'verified'),\n    ('[LB 7.776] rogii-ridge-sp title', 7.776, 'lightningv08/lb-7-776-rogii-ridge-sp', 'title-claim'),\n    ('[ROGII] BETTER SOLUTION title', 9.956, 'romantamrazov/rogii-better-solution-lb-9-956', 'title-claim'),\n    ('DWT-based title', 9.251, 'nihilisticneuralnet/9-251-rogii-wellbore-geology-prediction-dwt-based', 'title-claim'),\n    ('XGB Starter title CV', 15.0, 'cdeotte/xgb-starter-cv-15', 'title-claim'),\n    ('NN Starter title CV', 15.5, 'cdeotte/nn-starter-cv-15-5', 'title-claim'),\n]:\n    series.append({'label': label, 'id': ident, 'value': value, 'provenance': prov})\n(plots/'score_ladder_verified_and_title_claims.json').write_text(json.dumps({\n    'title': 'Score ladder: verified public LB bands plus notebook-title claims',\n    'source': 'leaderboard_snapshot.csv and kernels_top80_vote.json titles; title claims are unverified',\n    'series': series,\n}, indent=2))\nprint('wrote json sidecars')\nPY\npython /tmp/create_rogii_plots.py\ncat > /nvidia-kaggle/demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_019/plots/render_plots.py <<'PY'\nimport json, pathlib, textwrap\nimport matplotlib.pyplot as plt\nfrom matplotlib.patches import Patch\nplot_dir=pathlib.Path(__file__).resolve().parent\nfiles=[\n    'public_leaderboard_top20_rmse',\n    'score_ladder_verified_and_title_claims',\n    'public_notebooks_top20_votes',\n    'discussions_top15_comments',\n]\nfor stem in files:\n    data=json.loads((plot_dir/f'{stem}.json').read_text())\n    series=data['series']\n    labels=[s['label'] for s in series]\n    values=[s['value'] for s in series]\n    prov=[s['provenance'] for s in series]\n    height=max(5, 0.38*len(series)+1.6)\n    fig, ax=plt.subplots(figsize=(11, height))\n    ypos=list(range(len(series)))\n    colors=[]; hatches=[]\n    for p in prov:\n        if p == 'verified':\n            colors.append('#1f77b4'); hatches.append('')\n        elif p == 'title-claim':\n            colors.append('#ffbb78'); hatches.append('///')\n        else:\n            colors.append('#2ca02c'); hatches.append('xx')\n    bars=ax.barh(ypos, values, color=colors, edgecolor='black', linewidth=0.4)\n    for bar, hatch in zip(bars, hatches):\n        bar.set_hatch(hatch)\n    ax.set_yticks(ypos)\n    ax.set_yticklabels([textwrap.fill(l, 42) for l in labels], fontsize=8)\n    ax.invert_yaxis()\n    if 'rmse' in stem or 'score_ladder' in stem:\n        ax.set_xlabel('RMSE / score (lower is better)')\n    elif 'votes' in stem:\n        ax.set_xlabel('Votes')\n    else:\n        ax.set_xlabel('Comments')\n    ax.set_title(data['title'], fontsize=11)\n    ax.grid(axis='x', alpha=0.25)\n    for bar, v in zip(bars, values):\n        ax.text(bar.get_width(), bar.get_y()+bar.get_height()/2, f' {v:g}', va='center', fontsize=8)\n    legend=[]\n    if 'verified' in prov:\n        legend.append(Patch(facecolor='#1f77b4', edgecolor='black', label='verified from this run'))\n    if 'title-claim' in prov:\n        legend.append(Patch(facecolor='#ffbb78', edgecolor='black', hatch='///', label='author title-claim, unverified'))\n    if 'derived' in prov:\n        legend.append(Patch(facecolor='#2ca02c', edgecolor='black', hatch='xx', label='derived'))\n    if legend:\n        ax.legend(handles=legend, loc='best', fontsize