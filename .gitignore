# Secrets — never commit
.env
.env.*
!.env.example

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local data / generated databases
data/
*.db

# Generated briefing artifacts (but keep the checked-in demo sample)
*_briefing.md
!demo/competition-intel-briefing/llm-20-questions_briefing.md

# Local CLI skill-discovery symlink (environment-specific, not portable)
.claude/

# Agentic demo run dirs: ignore everything under runs/ EXCEPT the committed
# verified exhibits (negated below). Keeps scratch run churn out of the repo
# while the demo's evidence dirs stay tracked.
demo/competition-intel-briefing/runs/*
!demo/competition-intel-briefing/runs/codex_FAIL_caught_hallucination/
!demo/competition-intel-briefing/runs/codex_spaceship-titanic_002/
!demo/competition-intel-briefing/runs/claude_spaceship-titanic_003/
!demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_002/
!demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_010/
!demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_015/
!demo/competition-intel-briefing/runs/codex_rogii-wellbore-geology-prediction_017/
# ...but never the multi-GB downloaded competition dataset an agent may fetch
# into a run dir; the brief/trace/plots are the exhibit, not the raw data.
demo/competition-intel-briefing/runs/*/data/

